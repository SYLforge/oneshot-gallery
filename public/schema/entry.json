{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "no": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "title": {
      "type": "object",
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1
        },
        "ko": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "en",
        "ko"
      ],
      "additionalProperties": false
    },
    "description": {
      "type": "object",
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1
        },
        "ko": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "en",
        "ko"
      ],
      "additionalProperties": false
    },
    "aesthetic": {
      "type": "string",
      "enum": [
        "washi-sumi-e",
        "neo-brutalist",
        "editorial-serif",
        "terminal-core",
        "luxury-fashion",
        "cinematic-dark",
        "glass-futurism",
        "playful-pop",
        "webtoon",
        "korean-traditional",
        "swiss-typographic",
        "organic-nature",
        "bento-product",
        "vaporwave"
      ]
    },
    "techniques": {
      "minItems": 1,
      "maxItems": 6,
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "scroll-scrub-pinned",
          "canvas-particles",
          "char-split-reveal",
          "feturbulence-texture",
          "typewriter",
          "ascii-render",
          "crt-scanline",
          "marquee",
          "drag-physics",
          "webgl-shader",
          "svg-line-draw",
          "clip-path-reveal",
          "pointer-parallax",
          "flip-layout",
          "sprite-scrub",
          "spring-press",
          "glass-specular",
          "text-path"
        ]
      }
    },
    "industry": {
      "minItems": 1,
      "maxItems": 3,
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "atelier",
          "publishing",
          "science",
          "entertainment",
          "fashion-beauty",
          "product",
          "retail-food",
          "culture",
          "wellness"
        ]
      }
    },
    "stack": {
      "type": "object",
      "properties": {
        "animation": {
          "type": "string",
          "enum": [
            "gsap-lenis",
            "motion",
            "css-only",
            "vanilla-js"
          ]
        },
        "styling": {
          "type": "string",
          "enum": [
            "tailwind",
            "vanilla-css"
          ]
        },
        "renderer": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "dom",
              "canvas",
              "svg",
              "webgl"
            ]
          }
        }
      },
      "required": [
        "animation",
        "styling",
        "renderer"
      ],
      "additionalProperties": false
    },
    "dependencies": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prompt": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "minLength": 1
        },
        "modelLabel": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "oneshot": {
          "type": "boolean"
        },
        "followUps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "model",
        "modelLabel",
        "tool",
        "date",
        "oneshot",
        "followUps"
      ],
      "additionalProperties": false
    },
    "media": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "code",
            "comfyui",
            "hybrid"
          ]
        },
        "provenance": {
          "type": "object",
          "properties": {
            "en": {
              "type": "string",
              "minLength": 1
            },
            "ko": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "en",
            "ko"
          ],
          "additionalProperties": false
        },
        "budgetKB": {
          "default": 5120,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 5120
        }
      },
      "required": [
        "source",
        "budgetKB"
      ],
      "additionalProperties": false
    },
    "theme": {
      "type": "string",
      "enum": [
        "light",
        "dark"
      ]
    },
    "accent": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "credits": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "name",
          "role"
        ],
        "additionalProperties": false
      }
    },
    "license": {
      "type": "string",
      "const": "MIT"
    },
    "published": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": [
    "slug",
    "no",
    "title",
    "description",
    "aesthetic",
    "techniques",
    "industry",
    "stack",
    "dependencies",
    "prompt",
    "media",
    "theme",
    "accent",
    "credits",
    "license",
    "published",
    "featured"
  ],
  "additionalProperties": false
}
